<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<style>
  .box :first-child{
    background-color: aqua;
  }
 
  .box :nth-child(3){
    background-color: bisque;
  }
  .box li a {
    background-color: rgb(246, 131, 0);
  }


</style>
<body>
    <div class="box">
        <h1>box1</h1>
        <h1>box2</h1>
        <h1>box3</h1>
        <h1>box4</h1>
        <h2>box5</h2>
        <li><a href=""></a>google</li>
        
       
    </div>
</body>
</html>